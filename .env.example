# ================================================================
# Academic RAG Agent 配置文件
# 复制本文件为 .env 并填入配置：
#   Windows: copy .env.example .env
# ================================================================

# ----------------------------------------------------------------
# 🆓 方案A：完全免费（推荐！用你已有的 Google 账号）
# LLM  → Gemini 2.0 Flash（免费，Google AI Studio）
# 向量  → 本地 HuggingFace 模型（无需联网，约90MB）
#
# 获取 Key：https://aistudio.google.com → API 密钥 → 创建 API 密钥
# Key 格式以 AIza 开头
# ----------------------------------------------------------------
OPENAI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
OPENAI_MODEL=gemini-2.0-flash

EMBEDDING_PROVIDER=local                          # 使用本地免费 Embedding
EMBEDDING_MODEL=all-MiniLM-L6-v2                 # 自动从 HuggingFace 下载

# ----------------------------------------------------------------
# 💰 方案B：DeepSeek（极便宜，效果更好）
# 价格约为 GPT-4o 的 1/30，适合有少量预算时
# 官网：https://platform.deepseek.com/
# ----------------------------------------------------------------
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_MODEL=deepseek-chat
# EMBEDDING_PROVIDER=local
# EMBEDDING_MODEL=all-MiniLM-L6-v2

# ----------------------------------------------------------------
# 💳 方案C：OpenAI 官方（效果最好，但需付费）
# ----------------------------------------------------------------
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small

# ----------------------------------------------------------------
# Agent 行为配置（一般不需要改）
# ----------------------------------------------------------------
VECTOR_STORE_PATH=./vector_store
MEMORY_WINDOW_SIZE=10
RETRIEVAL_TOP_K=4
MAX_TOKENS=2048
