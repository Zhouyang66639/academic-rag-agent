# ================================================================
# Academic RAG Agent — Configuration Template
# Copy this file to .env:  copy .env.example .env
# Then fill in your API key.
# ================================================================

# ----------------------------------------------------------------
# Option A: SiliconFlow (Recommended — free Chinese phone signup)
# LLM  -> Qwen2.5-72B-Instruct (free credits on signup)
# Embed -> FastEmbed BAAI/bge-small-en-v1.5 (local ONNX, no PyTorch)
#
# Sign up: https://cloud.siliconflow.cn
# Get key: Dashboard -> API Keys -> New Key  (starts with sk-)
# ----------------------------------------------------------------
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.siliconflow.cn/v1
OPENAI_MODEL=Qwen/Qwen2.5-72B-Instruct

EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ----------------------------------------------------------------
# Option B: Groq (Requires Gmail — ultra-fast Llama inference)
# Sign up: https://console.groq.com  (key starts with gsk_)
# ----------------------------------------------------------------
# OPENAI_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_MODEL=llama-3.3-70b-versatile
# EMBEDDING_PROVIDER=local
# EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ----------------------------------------------------------------
# Option C: DeepSeek (Very cheap ~$0.002/1K tokens, best quality)
# Sign up: https://platform.deepseek.com
# ----------------------------------------------------------------
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_MODEL=deepseek-chat
# EMBEDDING_PROVIDER=local
# EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ----------------------------------------------------------------
# Agent behaviour (defaults are fine, edit if needed)
# ----------------------------------------------------------------
VECTOR_STORE_PATH=./vector_store
MEMORY_WINDOW_SIZE=10
RETRIEVAL_TOP_K=4
MAX_TOKENS=2048
